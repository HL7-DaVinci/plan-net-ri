# FHIR Server Configuration
# These can be set as environment variables or configured at runtime via public/config.js

# JSON array of FHIR servers for the server picker
# VITE_FHIR_SERVERS='[{"name":"Local Server","url":"http://localhost:8080/fhir"},{"name":"Public HAPI R4","url":"https://hapi.fhir.org/baseR4"}]'

# Enable single-server mode (hides server picker)
# VITE_SINGLE_SERVER_MODE=true

# Base URL of the Directory Crawler API (defaults to the selected FHIR server origin)
# VITE_API_BASE_URL=http://localhost:8080
